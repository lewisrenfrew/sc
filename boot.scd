// Run this first each session.
// Place cursor on a line and evaluate with Ctrl+Enter (Cmd+Enter on Mac).

// Boot the default server
s.boot;

// Check it's running
s.serverRunning;

// See active synths / CPU usage in a little meter window
s.meter;

// Stop everything currently sounding (panic button) — keyboard shortcut is usually Ctrl+.
s.freeAll;

// Quit the server when you're done for the session
s.quit;
